# Copy to frontend/.env (gitignored).
#
# Optional: only needed when the API is on a *different* origin than the SPA (e.g. local dev:
# Vite on :5173, API on :8000). Production behind Nginx (same host + `/api` proxy) can omit this;
# the app uses same-origin `/api/...` automatically.
# VITE_API_BASE_URL=http://localhost:8000
