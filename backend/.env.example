# Copy to backend/.env (gitignored) and fill in real values. Never commit secrets.

# CORS: include your frontend origin(s), comma-separated (no spaces after comma is safest)
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.example

# iNaturalist OAuth
# INAT_CLIENT_ID=
# INAT_CLIENT_SECRET=
# Must match an "Redirect URI" on https://www.inaturalist.org/oauth/applications exactly
# Local dev example (add this URL in your iNat app if you test locally):
# INAT_REDIRECT_URI=http://localhost:8000/api/auth/inat/callback
# Production example:
# INAT_REDIRECT_URI=https://your-api.example.com/api/auth/inat/callback
# Where to send the browser after a successful login (your React app)
# INAT_FRONTEND_SUCCESS_URL=http://localhost:5173/predict?inat=connected
# Optional OAuth scopes (space-separated)
# INAT_SCOPES=
# For local http://localhost:8000 + http://localhost:5173, lax is usually fine
# INAT_COOKIE_SAMESITE=lax
# Secure flag for session cookie: auto (HTTPS request only), true, or false
# INAT_COOKIE_SECURE=auto

# Dev only: enables POST /api/auth/mock-login
# ENABLE_INAT_MOCK_AUTH=false
