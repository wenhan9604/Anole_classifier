# CORS: include your production frontend origin (comma-separated)
# CORS_ORIGINS=https://your-frontend.example

# iNaturalist OAuth (required for /api/auth/inat/* and authenticated uploads)
# INAT_CLIENT_ID=
# INAT_CLIENT_SECRET=
# Callback must match exactly what you registered on iNaturalist:
# INAT_REDIRECT_URI=https://your-api.example.com/api/auth/inat/callback
# After login, user is sent here (include ?inat=connected for in-app toast):
# INAT_FRONTEND_SUCCESS_URL=https://your-frontend.example/predict?inat=connected
# Optional OAuth scopes (space-separated)
# INAT_SCOPES=
# Cross-site API + frontend: use none + HTTPS (cookie will be Secure)
# INAT_COOKIE_SAMESITE=lax

# Dev only: re-enable POST /api/auth/mock-login
# ENABLE_INAT_MOCK_AUTH=false
